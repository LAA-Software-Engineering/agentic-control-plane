{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["summary", "findings"],
  "properties": {
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "title", "evidence"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low", "info"]
          },
          "file": { "type": "string" },
          "title": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
